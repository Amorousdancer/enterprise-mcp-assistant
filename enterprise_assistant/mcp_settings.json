{
  "mcpServers": {
    "mysql-enterprise": {
      "command": "python",
      "args": ["mysql_mcp_server.py"],
      "env": {
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "",
        "MYSQL_DATABASE": "enterprise_db"
      },
      "disabled": false
    },
    "csv-enterprise": {
      "command": "python",
      "args": ["mcp_servers/csv_server.py"],
      "env": {
        "CSV_DATA_DIR": "sample_data"
      },
      "disabled": false
    },
    "redis-enterprise": {
      "command": "python",
      "args": ["mcp_servers/redis_server.py"],
      "env": {
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0"
      },
      "disabled": false
    }
  }
}
